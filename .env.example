# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Gmail account that SENDS the report
GMAIL_SENDER=yourname@gmail.com

# Gmail App Password (NOT your login password)
# Steps: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Who receives the report
RECIPIENT_EMAIL=zsp517013@gmail.com
